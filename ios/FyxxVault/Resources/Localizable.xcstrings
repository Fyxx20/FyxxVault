    "recovery.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Recovery Key" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Clé de récupération" } }
      }
    },
    "recovery.warning": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "If you forget your master password, this key is the ONLY way to recover your account. It will not be displayed again." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Si vous oubliez votre mot de passe maître, cette clé est le SEUL moyen de récupérer votre compte. Elle ne sera plus affichée." } }
      }
    },
    "recovery.button.copy": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Copy key" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Copier la clé" } }
      }
