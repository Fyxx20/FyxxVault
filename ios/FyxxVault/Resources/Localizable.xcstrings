    "recovery.tip.no_unencrypted": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Do not store it in an unencrypted file" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ne la stockez pas dans un fichier non chiffré" } }
