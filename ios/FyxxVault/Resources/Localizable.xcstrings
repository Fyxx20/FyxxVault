      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Your credentials are stored with AES-GCM 256-bit and HMAC-SHA256." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Tes identifiants sont stockés avec AES-GCM 256-bit et HMAC-SHA256." } }
