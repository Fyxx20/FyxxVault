    "auth.panic.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The panic password immediately wipes the entire vault if used instead of the master password." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Le mot de passe panic efface immédiatement tout le coffre si utilisé à la place du mot de passe maître." } }
      }
