    "recovery.tip.write_down": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Write it down on paper in a safe place" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Notez-la sur papier dans un endroit sûr" } }
      }
    },
    "recovery.tip.never_share": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Never share it" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ne la partagez jamais" } }
